{
  "name": "yashikota",
  "main": "src/worker.ts",
  "preview_urls": true,
  "vars": {
    "BUN_VERSION": "1.3.3"
  },
  "compatibility_date": "2025-05-29",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [{ "pattern": "yashikota.com", "custom_domain": true }],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true
  }
}
