---
import { Navigation } from "@/components/shadcn/navigation";
import { WorksPage } from "@/components/shadcn/works-page";
import Base from "@/layouts/base.astro";
import { getAllWorks } from "@/lib/works";

// Get works data
const works = await getAllWorks();
---

<Base
    pageTitle="Works"
    description="個人開発やチーム開発で制作した作品・プロダクトを一覧で紹介しています。"
    canonicalUrl="/works"
>
    <div>
        <Navigation client:load currentTab="works" />
        <WorksPage client:load works={works} />
    </div>
</Base>
